# Ensure shell scripts and env files use LF line endings, even when checked out
# on Windows (Git Bash). CRLF in scripts/.env corrupts values and breaks `head`/
# `tail` pipelines. `text=auto eol=lf` normalizes on commit + checkout.

* text=auto eol=lf

*.sh   text eol=lf
*.env  text eol=lf
.env   text eol=lf
*.go   text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sql  text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.ico binary
