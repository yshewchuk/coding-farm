# Frontend environment variables (Vite import.meta.env).
# Copy to .env.local and fill in.

# Management API origin. Leave empty in dev (Vite proxies /api to :8080).
VITE_API_BASE=

# Logto IdP endpoint + SPA app id.
VITE_LOGTO_ENDPOINT=http://localhost:3001
VITE_LOGTO_APP_ID=your-logto-app-id

# Optional: Logto API resource indicator (audience) for access tokens.
VITE_LOGTO_RESOURCE=

# OIDC scopes to request.
VITE_LOGTO_SCOPES=openid profile email
