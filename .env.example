# Cloud Sandbox platform — root .env for scripts/deploy.sh.
# Copy to .env and fill in. Never commit .env.

# ---- Fly.io ----
FLY_ORG=my-fly-org
FLY_API_TOKEN=fly_xxxxxxxxxxxxxxxxxxxx
# Optional: override the default Fly app name (default cloudsandbox-api).
# FLY_APP=cloudsandbox-api
FLY_REGION=iad

# ---- Database (Neon Serverless Postgres) ----
# Leave blank to auto-create via neonctl (run: scripts/deploy.sh neon-create),
# or paste a connection string from the Neon console.
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/cloudsandbox?sslmode=require

# ---- Frontend (public origin) ----
FRONTEND_URL=http://localhost:5173

# ---- Logto (OIDC IdP) ----
LOGTO_ISSUER=https://your-tenant.logto.app
# The API resource indicator (audience) the backend validates on every request.
LOGTO_AUDIENCE=https://api.example.com

# One-time M2M seed: create a "Machine-to-machine" app in the Logto console and
# grant it the built-in "Logto Management API" role (scope: all). Required only
# for `scripts/deploy.sh logto-setup`; leave blank until created.
# See: scripts/deploy.sh logto
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# Auto-set by `scripts/deploy.sh logto-setup` (the SPA application id). Leave
# blank to have logto-setup create the SPA app and write this for you.
LOGTO_APP_ID=

# Optional: name used to find/create the Logto SPA app (default "Cloud Sandbox").
# LOGTO_SPA_APP_NAME=Cloud Sandbox
