# Cloud Sandbox Management API — environment variables.
# Copy to .env and fill in. Never commit .env.

# ---- HTTP ----
HTTP_ADDR=:8080
# Public origin of the React UI (CORS). For local dev: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---- Database (Neon Serverless Postgres) ----
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/cloudsandbox?sslmode=require

# ---- Fly.io ----
FLY_API_TOKEN=fly_xxxxxxxxxxxxxxxxxxxx
FLY_ORG=my-fly-org
FLY_API_BASE_URL=https://api.machines.dev
FLY_REGION=iad
WORKSPACE_PORT=8080
# Optional: ship a pre-built image so sessions can launch before any template build.
# DEFAULT_IMAGE_REF=registry.fly.io/codeserver-workspace:latest

# ---- Logto (OIDC IdP) ----
LOGTO_ISSUER=https://logto.example.com
# Optional: expected token audience (Logto resource indicator).
# LOGTO_AUDIENCE=https://api.cloudsandbox.example
# Optional: override the JWKS endpoint (defaults to <issuer>/jwks).
# LOGTO_JWKS_URL=https://logto.example.com/jwks
# JWT claim carrying the organization id (multi-tenant). Defaults to organization_id.
LOGTO_ORG_CLAIM=organization_id
JWKS_REFRESH_INTERVAL=15m
